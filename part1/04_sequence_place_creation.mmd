sequenceDiagram
actor Client as User
participant API as Presentation(API)
participant Facade as HBnBFacade
participant BLL as BusinessLogic(PlaceService)
participant UserRepo as Persistence(UserRepository)
participant AmenityRepo as Persistence(AmenityRepository)
participant PlaceRepo as Persistence(PlaceRepository)

Client->>API: POST /places {title,description,price,lat,long,amenity_ids}
API->>API: AuthN/AuthZ + validate payload
API->>Facade: create_place(owner_id, data)

Facade->>BLL: create_place(owner_id, data)

%% Check owner exists
BLL->>UserRepo: get_by_id(owner_id)
UserRepo-->>BLL: owner or null

alt if owner not found
  BLL-->>Facade: Error: OwnerNotFound
  Facade-->>API: 404 Not Found
  API-->>Client: 404 {error}
else else
  %% Validate business rules
  BLL->>BLL: validate_place(data)\n(price>0, lat/long ranges)

  %% Optional amenities validation
  opt if amenity_ids provided
    BLL->>AmenityRepo: get_by_ids(amenity_ids)
    AmenityRepo-->>BLL: amenities list
    opt if some amenities missing
      BLL-->>Facade: Error: InvalidAmenity
      Facade-->>API: 400 Bad Request
      API-->>Client: 400 {error}
    end
  end

  %% Create entity and persist
  BLL->>BLL: place = Place(data, owner)
  opt amenities list
    loop each amenity
      BLL->>BLL: place.add_amenity(amenity)
    end
  end

  BLL->>PlaceRepo: create(place)
  PlaceRepo-->>BLL: saved place (id, timestamps)

  BLL-->>Facade: place DTO
  Facade-->>API: 201 Created (place DTO)
  API-->>Client: 201 {id,title,price,owner_id,amenity_ids}
end